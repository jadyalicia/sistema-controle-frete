<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fretes.front.controller.TransportadoraController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Cadastro de Transportadoras"
           style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <HBox spacing="10">
        <TextField fx:id="txtNome" promptText="Nome"/>
        <TextField fx:id="txtCnpj" promptText="CNPJ"/>
        <TextField fx:id="txtContato" promptText="Contato"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Novo" onAction="#novo"/>
        <Button text="Salvar" onAction="#salvar"/>
        <Button text="Excluir" onAction="#excluir"/>
    </HBox>

    <TableView fx:id="tblTransportadoras">
        <columns>
            <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
            <TableColumn fx:id="colCnpj" text="CNPJ" prefWidth="150"/>
            <TableColumn fx:id="colContato" text="Contato" prefWidth="200"/>
        </columns>
    </TableView>

</VBox>