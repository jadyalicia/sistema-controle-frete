<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700" prefWidth="1000" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fretes.front.controller.MainController">

    <!-- ================= TOPO ================= -->
    <top>
        <HBox spacing="10" style="-fx-background-color: #34495e;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Controle de Fretes" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Sair" />
            </children>
        </HBox>
    </top>

    <!-- ================= MENU LATERAL ================= -->
    <left>
        <VBox prefWidth="200" spacing="15" style="-fx-background-color: #2c3e50;">

            <padding>
                <Insets bottom="20" left="10" right="10" top="20" />
            </padding>

            <children>

                <Label style="-fx-text-fill: white; -fx-font-size: 16px;" text="Menu" />

                <Button onAction="#abrirTransportadora" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Cadastro Transportadora" />

                <Button onAction="#abrirPedido" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Cadastro Pedido" />

                <Button onAction="#abrirTabeladeFrete" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Tabela de Frete" />

                <Button onAction="#abrirDashboard" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Dashboard" />

                <Button onAction="#abrirRelatorios" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Relatorios" />

                <Button onAction="#abrirRanking" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Ranking" />

                <Button onAction="#abrirFretes" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Fretes" />
            



            </children>
        </VBox>
    </left>

    <!-- ================= CENTRO DINÂMICO ================= -->
    <center>
        <AnchorPane fx:id="contentArea" />
    </center>

    <!-- ================= RODAPÉ ================= -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="30" style="-fx-background-color: #ecf0f1;">

            <children>
                <Label text="Sistema Controle de Fretes v1.0" />
            </children>
        </HBox>
    </bottom>

</BorderPane>
