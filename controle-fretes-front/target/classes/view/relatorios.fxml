<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fretes.front.controller.RelatorioController">

    <!-- TÍTULO -->
    <Label style="-fx-font-size:18; -fx-font-weight:bold;" text="Acompanhamento de Fretes" />

    <!-- FILTROS (ERP STYLE) -->
    <HBox spacing="10">

        <TextField fx:id="txtBusca" prefWidth="300" promptText="Buscar por pedido / NF / destino..." />

        <Button text="Buscar" />
        <Button text="Atualizar" />

    </HBox>

    <!-- TABELA -->
    <TableView fx:id="tblFretes" editable="true" VBox.vgrow="ALWAYS">

        <columns>

            <TableColumn fx:id="colId" prefWidth="60" text="ID" />

            <TableColumn fx:id="colPedido" prefWidth="120" text="Pedido" />

            <TableColumn fx:id="colTransportadora" prefWidth="160" text="Transportadora" />

            <TableColumn fx:id="colPeso" prefWidth="90" text="Peso" />

            <TableColumn fx:id="colCubagem" prefWidth="90" text="Cubagem" />

            <TableColumn fx:id="colValor" prefWidth="100" text="Valor" />

            <!-- EDITÁVEIS -->
            <TableColumn fx:id="colNF" prefWidth="130" text="NF" />

            <TableColumn fx:id="colCTe" prefWidth="130" text="CTe" />

            <TableColumn fx:id="colStatus" prefWidth="140" text="Status" />

        </columns>

    </TableView>

</VBox>
