<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fretes.front.controller.RelatorioController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Acompanhamento de Fretes "
           style="-fx-font-size:18px; -fx-font-weight:bold;"/>

    <!-- FILTROS -->
    <HBox spacing="10">
        <TextField fx:id="txtBusca"
                   promptText="Buscar por pedido / NF / destino..."
                   prefWidth="300"/>
        <Button text="Buscar" onAction="#buscar"/>
        <Button text="Atualizar" onAction="#atualizar"/>
    </HBox>

    <!-- BOTÕES DE EXPORTAÇÃO -->
    <HBox spacing="10">
        <Button text="Exportar Excel" onAction="#exportarExcel"/>
        <Button text="Exportar PDF" onAction="#exportarPDF"/>
    </HBox>

    <!-- TABELA -->
    <TableView fx:id="tblFretes"
               editable="true"
               VBox.vgrow="ALWAYS">

        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colPedido" text="Pedido" prefWidth="120"/>
            <TableColumn fx:id="colTransportadora" text="Transportadora" prefWidth="160"/>
            <TableColumn fx:id="colPeso" text="Peso" prefWidth="90"/>
            <TableColumn fx:id="colCubagem" text="Cubagem" prefWidth="90"/>
            <TableColumn fx:id="colValor" text="Valor" prefWidth="100"/>
            <TableColumn fx:id="colNF" text="NF" prefWidth="130"/>
            <TableColumn fx:id="colCTe" text="CTe" prefWidth="130"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="140"/>
        </columns>

    </TableView>

</VBox>