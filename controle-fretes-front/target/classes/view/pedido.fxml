<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fretes.front.controller.PedidoController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <!-- Título -->
    <Label style="-fx-font-size:18px; -fx-font-weight:bold;" text="Cadastro de Pedido" />

    <!-- Formulário -->
    <HBox spacing="10">
        <TextField fx:id="txtNumeroPedido" promptText="Número do Pedido" />
        <TextField fx:id="txtCliente" promptText="Cliente" />
        <TextField fx:id="txtCidade" promptText="Cidade" />
        <TextField fx:id="txtEstado" promptText="Estado" />
        <TextField fx:id="txtPeso" promptText="Peso (kg)" />
        <TextField fx:id="txtCubagem" promptText="Cubagem (m³)" />
    </HBox>

    <!-- Botões -->
    <HBox spacing="10">
        <Button onAction="#novoPedido" text="Novo" />
        <Button onAction="#cadastrarPedido" text="Cadastrar" />
        <Button onAction="#excluirPedido" text="Excluir" />
    </HBox>

    <!-- Tabela -->
    <TableView fx:id="tblPedidos">
        <columns>
            <TableColumn fx:id="colNumeroPedido" prefWidth="120" text="Número do Pedido" />
            <TableColumn fx:id="colCliente" prefWidth="150" text="Cliente" />
            <TableColumn fx:id="colCidade" prefWidth="120" text="Cidade" />
            <TableColumn fx:id="colEstado" prefWidth="80" text="Estado" />
            <TableColumn fx:id="colPeso" prefWidth="100" text="Peso (kg)" />
            <TableColumn fx:id="colCubagem" prefWidth="100" text="Cubagem (m³)" />
        </columns>
    </TableView>

</VBox>
