<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="15"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fretes.front.controller.RankingController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Ranking de Cotação (TOP 3)"
           style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <!-- Botão sem onAction para evitar erro -->
    <Button text="Calcular Cotação" />

    <TableView fx:id="tblRanking">

        <columns>
            <TableColumn fx:id="colPosicao" text="Posição" prefWidth="100"/>
            <TableColumn fx:id="colTransportadora" text="Transportadora" prefWidth="250"/>
            <TableColumn fx:id="colValor" text="Valor (R$)" prefWidth="150"/>
        </columns>

    </TableView>

</VBox>