<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.LoginController">
    <Label text="Login"/>
    <TextField fx:id="txtUsername" promptText="Usuário"/>
    <PasswordField fx:id="txtPassword" promptText="Senha"/>
    <Button text="Entrar" onAction="#handleLogin"/>
    <Label fx:id="lblMessage" style="-fx-text-fill:red"/>
</VBox>