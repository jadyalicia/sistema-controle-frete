<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FreteController">
    <Label text="Fretes"/>
    <TableView fx:id="tblFretes">
        <columns>
            <TableColumn text="ID" fx:id="colId"/>
            <TableColumn text="Transportadora" fx:id="colTransportadora"/>
            <TableColumn text="Valor" fx:id="colValor"/>
        </columns>
    </TableView>
    <Button text="Novo Frete" onAction="#addFrete"/>
</VBox>