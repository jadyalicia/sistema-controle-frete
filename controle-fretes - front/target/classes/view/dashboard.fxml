<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.DashboardController">
    <Label text="Dashboard"/>
    <Button text="Carregar Ranking" onAction="#loadRanking"/>
    <TableView fx:id="tblRanking">
        <columns>
            <TableColumn text="Transportadora" fx:id="colTransportadora"/>
            <TableColumn text="Qtd Fretes" fx:id="colQtdFretes"/>
        </columns>
    </TableView>
    <Button text="Nova Cotação" onAction="#novaCotacao"/>
</VBox>