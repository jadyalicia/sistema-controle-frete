<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FreteFormController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Frete" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    
    <ComboBox fx:id="transportadoraCombo" promptText="Transportadora"/>
    <TextField fx:id="valorField" promptText="Valor"/>
    <DatePicker fx:id="dataPicker"/>

    <Button text="Salvar" onAction="#salvar"/>
    <Button text="Cancelar" onAction="#cancelar"/>
</VBox>