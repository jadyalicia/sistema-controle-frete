package controller;

import javafx.fxml.FXML;
import javafx.scene.control.Label;
import javafx.scene.control.Button;
import javafx.fxml.FXMLLoader;
import javafx.scene.Scene;
import javafx.stage.Stage;
import org.json.JSONObject;
import service.ApiService;

public class DashboardController {

    @FXML private Label totalFretesLabel, valorTotalLabel, valorMedioLabel, transportadoraLabel;
    @FXML private Button verFretesButton;

    @FXML
    public void initialize() {
        try {
            String json = ApiService.getDashboard();
            JSONObject obj = new JSONObject(json);
            totalFretesLabel.setText(String.valueOf(obj.getInt("totalFretes")));
            valorTotalLabel.setText(String.valueOf(obj.getDouble("valorTotal")));
            valorMedioLabel.setText(String.valueOf(obj.getDouble("valorMedio")));
            transportadoraLabel.setText(obj.getString("transportadoraMaisUsada"));
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    @FXML
    private void handleVerFretes() throws Exception {
        FXMLLoader loader = new FXMLLoader(getClass().getResource("/view/fretes.fxml"));
        Stage stage = (Stage) verFretesButton.getScene().getWindow();
        stage.setScene(new Scene(loader.load()));
    }
}