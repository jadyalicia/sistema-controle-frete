package model;

public class Frete {
    private Long id;
    private String transportadora;
    private double valor;
    private String data;

    public Frete(Long id, String transportadora, double valor, String data){
        this.id=id; this.transportadora=transportadora; this.valor=valor; this.data=data;
    }

    public Long getId(){return id;}
    public String getTransportadora(){return transportadora;}
    public double getValor(){return valor;}
    public String getData(){return data;}
}